# =============================================================================
# VARIABLES DE ENTORNO - Sistema de Gimnasio Backend
# =============================================================================
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como .env en la raíz del proyecto
# 2. Reemplazar los valores de ejemplo con tus valores reales
# 3. NUNCA commitear el archivo .env a Git
#
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS - PostgreSQL
# -----------------------------------------------------------------------------
DB_USERNAME=postgres
DB_PASSWORD=CAMBIAR_ESTE_PASSWORD_SEGURO

# Nombres de bases de datos (no cambiar a menos que modifiques el código)
DB_NAME_AUTH=gym_authentication
DB_NAME_EXERCISE=gym_exercise

# -----------------------------------------------------------------------------
# JWT (JSON Web Tokens)
# -----------------------------------------------------------------------------
# Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_ESTE_SECRET_MUY_LARGO_Y_SEGURO_GENERADO_CON_OPENSSL

# Expiración del token en milisegundos (por defecto 24 horas)
JWT_EXPIRATION=86400000

# -----------------------------------------------------------------------------
# EMAIL SERVICE - Resend API
# -----------------------------------------------------------------------------
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_CAMBIAR_ESTA_API_KEY_DE_RESEND

# -----------------------------------------------------------------------------
# ADMIN SERVICE (Spring Boot Admin)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIAR_ESTE_PASSWORD_DEL_ADMIN

# -----------------------------------------------------------------------------
# SPRING PROFILES
# -----------------------------------------------------------------------------
# Valores posibles: dev, docker, prod
SPRING_PROFILES_ACTIVE=docker

# -----------------------------------------------------------------------------
# ZIPKIN (Distributed Tracing) - Opcional
# -----------------------------------------------------------------------------
ZIPKIN_ENABLED=false
ZIPKIN_BASE_URL=http://localhost:9411

# -----------------------------------------------------------------------------
# RABBITMQ - Configuración
# -----------------------------------------------------------------------------
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# -----------------------------------------------------------------------------
# EUREKA SERVER
# -----------------------------------------------------------------------------
EUREKA_HOST=eureka-server
EUREKA_PORT=8761

# -----------------------------------------------------------------------------
# CONFIG SERVER - Configuración Centralizada
# -----------------------------------------------------------------------------
CONFIG_SERVER_HOST=config-service
CONFIG_SERVER_PORT=8889

# Repositorio Git para configuraciones (cambiar si usas tu propio repo)
CONFIG_GIT_URI=https://github.com/EmaSleal/config-server.git

# -----------------------------------------------------------------------------
# NOTAS IMPORTANTES
# -----------------------------------------------------------------------------
#
# SEGURIDAD:
# - Rotar todos los secretos después de clonar este proyecto
# - Usar contraseñas fuertes (mínimo 16 caracteres)
# - JWT_SECRET debe ser al menos 256 bits (64 caracteres en base64)
# - NUNCA usar estos valores en producción
#
# GENERACIÓN DE SECRETOS SEGUROS:
# - JWT Secret: openssl rand -base64 64
# - Passwords: openssl rand -base64 32
# - API Keys: Obtener de los servicios oficiales
#
# DOCKER COMPOSE:
# Este archivo .env es leído automáticamente por docker-compose.yml
# Las variables están disponibles en los servicios configurados
#
# =============================================================================
